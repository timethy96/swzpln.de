# Open Topo Data API Key
# Get your API key from https://www.opentopodata.org/
OPENTOPODATA_API_KEY=your_api_key_here

# Overpass API (primary data source, leave empty to use client-side Overpass fallback)
# For Docker: http://swzpln-overpass/api/interpreter
# For development with public instance: https://overpass-api.de/api/interpreter
OVERPASS_URL=

# Overpass cache TTL in hours (default: 24)
# OVERPASS_CACHE_TTL_HOURS=24

# Show shop and donate links (set to "false" to hide)
PUBLIC_SHOW_SHOP=true
