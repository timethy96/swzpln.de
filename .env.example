# Open Topo Data API Key
# Get your API key from https://www.opentopodata.org/
OPENTOPODATA_API_KEY=your_api_key_here

# PostGIS (primary data source, leave empty to use Overpass API fallback)
# For development: postgres://user:password@localhost:5432/dbname
# For Docker: postgres://user:password@swzpln-postgis:5432/dbname
POSTGIS_URL=

# Show shop and donate links (set to "false" to hide)
PUBLIC_SHOW_SHOP=true
